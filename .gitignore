# ── .NET ──────────────────────────────────────────────────────────────────────
bin/
obj/
*.user
*.suo
.vs/

# EF Core 数据库文件（运行时生成）
**/*.db
**/*.db-shm
**/*.db-wal

# 用户本地配置（可覆盖 appsettings.json，可能含密钥）
appsettings.local.json
appsettings.*.local.json

# ── 前端 ──────────────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.*.local

# ── 环境变量 / 密钥（绝对不能入库）────────────────────────────────────────────
.env
.env.local
.env.*.local
# .env.example 是模板，应当入库

# ── 运行时数据 ─────────────────────────────────────────────────────────────────
data/
media/
logs/

# ── IDE / 工具 ────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.claude/

# ── 操作系统 ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
